# Per spec module 01: configuration is typically a TOML file mounted into the backend
# container, but the development stack uses environment variables via docker-compose.
# Copy this file to `.env` if you need to override defaults; the Compose file already
# sets sensible development defaults so this is optional.

# Backend
TALLYKEEP_ENVIRONMENT=development
TALLYKEEP_API_HOST=0.0.0.0
TALLYKEEP_API_PORT=8000

# Postgres (matches docker-compose defaults)
TALLYKEEP_DATABASE_URL=postgresql+psycopg://tallykeep:tallykeep_dev@postgres:5432/tallykeep

# Redis
TALLYKEEP_REDIS_URL=redis://redis:6379/0

# bitcoind (regtest defaults from docker-compose)
TALLYKEEP_BITCOIND_RPC_URL=http://tallykeep:tallykeep_dev@bitcoind:18443
TALLYKEEP_BITCOIND_ZMQ_BLOCK_ENDPOINT=tcp://bitcoind:28332
TALLYKEEP_BITCOIND_ZMQ_TX_ENDPOINT=tcp://bitcoind:28333
